{
    "paths": [
        "src"
    ],
    "metrics": {
        "cyclomaticComplexity": {
            "skip": [
                "App\\Entity\\SomeEntity",
                "App\\Service\\*Generated",
                "App\\**\\SomeApiResource",
            ],
            "maxValue": 10
        },
        "efferentCoupling": {
            "skip": [
                "App\\Service\\SomeService"
            ],
            "maxValue": 12
        }
    }
}
